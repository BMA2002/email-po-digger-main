{
  "buildCommand": "cd email-po-digger-main && bun run build",
  "devCommand": "cd email-po-digger-main && bun run dev",
  "installCommand": "cd email-po-digger-main && bun install",
  "framework": "vite",
  "outputDirectory": "email-po-digger-main/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
